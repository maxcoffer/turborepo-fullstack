{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "public": false,
  "github": {
    "enabled": false
  },
  "outputDirectory": "api",
  "buildCommand": "turbo run build --filter=@monorepo/server --only",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "src/main.ts"
    }
  ]
}